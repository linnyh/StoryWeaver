# StoryWeaver 后端环境变量示例
# 复制此文件为 .env 并填写实际值：cp .env.example .env

# ----- 必填：LLM 接口 -----
# OpenAI 兼容 API（如 OpenAI / DeepSeek / 其他兼容服务）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 可选：通过 MODEL 覆盖当前使用的模型（例如 abab6.5s-chat）
# MODEL=abab6.5s-chat

# ----- 可选：MiniMax 等 -----
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=

# ----- 数据库 -----
# 默认 SQLite；生产可改为 PostgreSQL
# DATABASE_URL=sqlite+aiosqlite:///./storyweaver.db

# ----- 向量库与嵌入 -----
# ChromaDB 持久化目录
# CHROMADB_PERSIST_DIRECTORY=./chroma_data
# 嵌入模型（用于 RAG）
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
